{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Sequoia Retro Light",
  "author": "Micheal Andreuzza",
  "themes": [
    {
      "name": "Sequoia Retro Light",
      "appearance": "light",
      "style": {
        "accents": [
          "#456a82ff",
          "#8a6539ff",
          "#5f7982ff",
          "#4a704eff",
          "#bf5238ff",
          "#5f7982ff",
          "#42434eff"
        ],
        "background": "#edeef2ff",
        "border": "#42434e33",
        "border.focused": "#8a653977",
        "border.selected": "#8a6539bb",
        "border.transparent": "#00000000",
        "elevated_surface.background": "#e2e3e8ff",
        "surface.background": "#edeef2ffee",
        "element.background": "#e2e3e8ff",
        "element.hover": "#42434eff",
        "element.selected": "#42434eff",
        "text": "#282930ff",
        "text.muted": "#42434eff",
        "text.accent": "#8a6539ff",
        "icon": "#282930ff",
        "icon.muted": "#42434eff",
        "status_bar.background": "#edeef2ff",
        "title_bar.background": "#edeef2ff",
        "toolbar.background": "#e2e3e8ff",
        "tab_bar.background": "#edeef2ff",
        "tab.inactive_background": "#edeef2ff",
        "tab.active_background": "#edeef2ff",
        "panel.background": "#edeef2ff",
        "editor.foreground": "#282930ff",
        "editor.background": "#edeef2ff",
        "editor.gutter.background": "#edeef2ff",
        "editor.active_line.background": "#42434e33",
        "editor.line_number": "#42434eff",
        "editor.active_line_number": "#282930ff",
        "scrollbar.thumb.background": "#42434e77",
        "scrollbar.track.background": "#edeef2ff",
        "terminal.background": "#edeef2ff",
        "terminal.foreground": "#282930ff",
        "terminal.ansi.black": "#d4d5dcff",
        "terminal.ansi.red": "#5f7982ff",
        "terminal.ansi.green": "#4a704eff",
        "terminal.ansi.yellow": "#bf5238ff",
        "terminal.ansi.blue": "#456a82ff",
        "terminal.ansi.magenta": "#c99730ff",
        "terminal.ansi.cyan": "#8a6539ff",
        "terminal.ansi.white": "#282930ff",
        "terminal.ansi.bright_black": "#42434eff",
        "terminal.ansi.bright_red": "#c99730ff",
        "terminal.ansi.bright_green": "#4a704eff",
        "terminal.ansi.bright_yellow": "#bf5238ff",
        "terminal.ansi.bright_blue": "#456a82ff",
        "terminal.ansi.bright_magenta": "#5f7982ff",
        "terminal.ansi.bright_cyan": "#8a6539ff",
        "terminal.ansi.bright_white": "#282930ff",
        "syntax": {
          "comment": {
            "color": "#565760ff",
            "font_style": "italic"
          },
          "keyword": {
            "color": "#4a704eff"
          },
          "string": {
            "color": "#bf5238ff"
          },
          "function": {
            "color": "#5f7982ff",
            "font_style": "italic"
          },
          "variable": {
            "color": "#8a6539ff",
            "font_style": "italic"
          },
          "type": {
            "color": "#456a82ff"
          },
          "constant": {
            "color": "#4a704eff"
          },
          "operator": {
            "color": "#42434eff"
          },
          "error": {
            "color": "#5f7982ff"
          }
        }
      }
    }
  ]
}
