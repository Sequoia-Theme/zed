        "terminal.ansi.black": "#131317ff",
        "terminal.ansi.red": "#999eb2ff",
        "terminal.ansi.green": "#626983ff",
        "terminal.ansi.yellow": "#d3d5deff",
        "terminal.ansi.blue": "#7c829dff",
        "terminal.ansi.magenta": "#e2e4edff",
        "terminal.ansi.cyan": "#b6bac8ff",
        "terminal.ansi.white": "#868690ff",
