{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Sequoia Retro Dark",
  "author": "Micheal Andreuzza",
  "themes": [
    {
      "name": "Sequoia Retro Dark",
      "appearance": "dark",
      "style": {
        "accents": [
          "#5c87a4ff",
          "#a27e57ff",
          "#829fa7ff",
          "#648f68ff",
          "#da674bff",
          "#829fa7ff",
          "#575861ff"
        ],
        "background": "#0f1014ff",
        "border": "#57586133",
        "border.focused": "#a27e5777",
        "border.selected": "#a27e57bb",
        "border.transparent": "#00000000",
        "elevated_surface.background": "#111216ff",
        "surface.background": "#0f1014ffee",
        "element.background": "#111216ff",
        "element.hover": "#575861ff",
        "element.selected": "#575861ff",
        "text": "#868690ff",
        "text.muted": "#575861ff",
        "text.accent": "#a27e57ff",
        "icon": "#868690ff",
        "icon.muted": "#575861ff",
        "status_bar.background": "#0f1014ff",
        "title_bar.background": "#0f1014ff",
        "toolbar.background": "#111216ff",
        "tab_bar.background": "#0f1014ff",
        "tab.inactive_background": "#0f1014ff",
        "tab.active_background": "#0f1014ff",
        "panel.background": "#0f1014ff",
        "editor.foreground": "#868690ff",
        "editor.background": "#0f1014ff",
        "editor.gutter.background": "#0f1014ff",
        "editor.active_line.background": "#57586133",
        "editor.line_number": "#575861ff",
        "editor.active_line_number": "#868690ff",
        "scrollbar.thumb.background": "#57586177",
        "scrollbar.track.background": "#0f1014ff",
        "terminal.background": "#0f1014ff",
        "terminal.foreground": "#868690ff",
        "terminal.ansi.black": "#131317ff",
        "terminal.ansi.red": "#829fa7ff",
        "terminal.ansi.green": "#648f68ff",
        "terminal.ansi.yellow": "#da674bff",
        "terminal.ansi.blue": "#5c87a4ff",
        "terminal.ansi.magenta": "#e8b246ff",
        "terminal.ansi.cyan": "#a27e57ff",
        "terminal.ansi.white": "#868690ff",
        "terminal.ansi.bright_black": "#575861ff",
        "terminal.ansi.bright_red": "#e8b246ff",
        "terminal.ansi.bright_green": "#648f68ff",
        "terminal.ansi.bright_yellow": "#da674bff",
        "terminal.ansi.bright_blue": "#5c87a4ff",
        "terminal.ansi.bright_magenta": "#829fa7ff",
        "terminal.ansi.bright_cyan": "#a27e57ff",
        "terminal.ansi.bright_white": "#868690ff",
