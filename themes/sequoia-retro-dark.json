          "comment": {
            "color": "#43444dff",
            "font_style": "italic"
          },
          "keyword": {
            "color": "#648f68ff"
          },
          "string": {
            "color": "#da674bff"
          },
          "function": {
            "color": "#829fa7ff",
            "font_style": "italic"
          },
          "variable": {
            "color": "#a27e57ff",
            "font_style": "italic"
          },
          "type": {
            "color": "#5c87a4ff"
          },
          "constant": {
            "color": "#648f68ff"
          },
          "operator": {
            "color": "#575861ff"
          },
          "error": {
            "color": "#829fa7ff"
          }
        }
      }
    }
