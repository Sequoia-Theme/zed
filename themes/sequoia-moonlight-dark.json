{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Sequoia Moonlight Dark",
  "author": "Micheal Andreuzza",
  "themes": [
    {
      "name": "Sequoia Moonlight Dark",
      "appearance": "dark",
      "style": {
        "accents": [
          "#c58fffff",
          "#ffbb88ff",
          "#f58ee0ff",
          "#8eb6f5ff",
          "#9898a6ff",
          "#f58ee0ff",
          "#575861ff"
        ],
        "background": "#0f1014ff",
        "border": "#57586133",
        "border.focused": "#ffbb8877",
        "border.selected": "#ffbb88bb",
        "border.transparent": "#00000000",
        "elevated_surface.background": "#111216ff",
        "surface.background": "#0f1014ffee",
        "element.background": "#111216ff",
        "element.hover": "#575861ff",
        "element.selected": "#575861ff",
        "text": "#868690ff",
        "text.muted": "#575861ff",
        "text.accent": "#ffbb88ff",
        "icon": "#868690ff",
        "icon.muted": "#575861ff",
        "status_bar.background": "#0f1014ff",
        "title_bar.background": "#0f1014ff",
        "toolbar.background": "#111216ff",
        "tab_bar.background": "#0f1014ff",
        "tab.inactive_background": "#0f1014ff",
        "tab.active_background": "#0f1014ff",
        "panel.background": "#0f1014ff",
        "editor.foreground": "#868690ff",
        "editor.background": "#0f1014ff",
        "editor.gutter.background": "#0f1014ff",
        "editor.active_line.background": "#57586133",
        "editor.line_number": "#575861ff",
        "editor.active_line_number": "#868690ff",
        "scrollbar.thumb.background": "#57586177",
        "scrollbar.track.background": "#0f1014ff",
        "terminal.background": "#0f1014ff",
        "terminal.foreground": "#868690ff",
        "terminal.ansi.black": "#131317ff",
        "terminal.ansi.red": "#f58ee0ff",
        "terminal.ansi.green": "#8eb6f5ff",
        "terminal.ansi.yellow": "#9898a6ff",
        "terminal.ansi.blue": "#c58fffff",
        "terminal.ansi.magenta": "#fdfdfeff",
        "terminal.ansi.cyan": "#ffbb88ff",
        "terminal.ansi.white": "#868690ff",
        "terminal.ansi.bright_black": "#575861ff",
        "terminal.ansi.bright_red": "#f58ee0ff",
        "terminal.ansi.bright_green": "#8eb6f5ff",
        "terminal.ansi.bright_yellow": "#9898a6ff",
        "terminal.ansi.bright_blue": "#c58fffff",
        "terminal.ansi.bright_magenta": "#fdfdfeff",
        "terminal.ansi.bright_cyan": "#ffbb88ff",
        "terminal.ansi.bright_white": "#868690ff",
        "syntax": {
          "comment": {
            "color": "#43444dff",
            "font_style": "italic"
          },
          "keyword": {
            "color": "#8eb6f5ff"
          },
          "string": {
            "color": "#9898a6ff"
          },
          "function": {
            "color": "#f58ee0ff",
            "font_style": "italic"
          },
          "variable": {
            "color": "#ffbb88ff",
            "font_style": "italic"
          },
          "type": {
            "color": "#c58fffff"
          },
          "constant": {
            "color": "#8eb6f5ff"
          },
          "operator": {
            "color": "#575861ff"
          },
          "error": {
            "color": "#f58ee0ff"
          }
        }
      }
    }
  ]
}
